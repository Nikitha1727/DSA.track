class Solution {
  public:
    int countFactors(int n) {
        // code here
        int c = 0;
        for(int i = 1 ; i*i <= n ; i++ ){
            if(n % i == 0){
                if(i == n/i){
                    c = c + 1;
                }
                else{
                    c = c + 2;
                }
            }
        }
        return c;
    }
};   

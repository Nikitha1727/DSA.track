class Solution {
  public:
  
    int evenlyDivides(int n) {
        int temp = n;
        int count = 0;
        
        while(n > 0){
            int digit = n % 10;
            
            if(digit != 0 && temp % digit == 0){
                count++;
            }
            
            n = n / 10;
        }
        
        return count;
    }
};
